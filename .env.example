# ───────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in the values.
# Never commit .env.local — it holds your secrets.
# ───────────────────────────────────────────────────────────────

# Admin (backend upload) password. Visitors don't need this.
ADMIN_PASSWORD=change-me

# Public base URL used when generating QR codes (no trailing slash).
# Local: http://localhost:3000   Vercel: https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── AI (packyapi / OpenAI-compatible relay) ──────────────────────
# Get a key at https://www.packyapi.com . Leave AI_API_KEY empty to run
# in MOCK mode (the whole flow works with canned answers, no key needed).
AI_API_KEY=
AI_BASE_URL=https://www.packyapi.com/v1
AI_MODEL=claude-opus-4-8

# ── Talking-avatar (digital human) provider ──────────────────────
# AVATAR_PROVIDER = mock | did
#   mock : no video; the photo "speaks" via the browser's built-in voice
#          (fully working demo, zero cost, no key required)
#   did  : real lip-sync video via D-ID (https://www.d-id.com) — needs a key
AVATAR_PROVIDER=mock
DID_API_KEY=
# Default D-ID voice (Microsoft voices). zh-CN-XiaoxiaoNeural / en-US-JennyNeural ...
DID_VOICE_ID=en-US-JennyNeural
